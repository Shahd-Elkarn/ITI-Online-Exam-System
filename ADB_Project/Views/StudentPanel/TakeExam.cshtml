@model ADB_Project.Models.ViewModels.TakeExamVM

@{
    ViewData["Title"] = "Take Exam - " + Model.ExamName;
    int remainingSeconds = ViewBag.RemainingSeconds ?? 0;
}

<style>
    /* تصميم النسخة الثانية */
    .exam-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 1.5rem;
    }

    /* Exam Header */
    .exam-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 15px;
        padding: 25px;
        margin-bottom: 25px;
        box-shadow: 0 10px 40px rgba(102, 126, 234, 0.3);
    }

    .exam-info {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .exam-icon {
        width: 60px;
        height: 60px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
    }

    .exam-title h2 {
        font-size: 1.5rem;
        margin: 0;
        color: white;
    }

    .exam-course {
        opacity: 0.9;
        font-size: 1rem;
        margin-top: 5px;
    }

    /* Timer */
    .timer-box {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(10px);
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        min-width: 200px;
    }

    .timer-label {
        font-size: 0.875rem;
        opacity: 0.9;
        margin-bottom: 5px;
    }

    .timer-display {
        font-family: monospace;
        font-size: 2rem;
        font-weight: 700;
        letter-spacing: 2px;
    }

    /* Layout */
    .exam-layout {
        display: grid;
        grid-template-columns: 1fr 350px;
        gap: 1.5rem;
    }

    /* Question Card */
    .question-card {
        background: white;
        border-radius: 15px;
        padding: 30px;
        box-shadow: 0 5px 20px rgba(0,0,0,.08);
        margin-bottom: 20px;
        min-height: 500px;
        display: flex;
        flex-direction: column;
    }

    .question-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 20px;
        margin-bottom: 20px;
        border-bottom: 2px solid #e9ecef;
    }

    .question-number {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 1.1rem;
        font-weight: 600;
        color: #6c757d;
    }

        .question-number i {
            color: #667eea;
        }

    .points-badge {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 8px 20px;
        border-radius: 50px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .question-text {
        font-size: 1.25rem;
        font-weight: 600;
        color: #212529;
        margin-bottom: 25px;
        line-height: 1.6;
    }

    /* Choices - وظائف النسخة الأولى */
    .choice-item {
        border: 2px solid #e9ecef;
        border-radius: 10px;
        padding: 15px;
        cursor: pointer;
        margin-bottom: 10px;
        display: flex;
        gap: 10px;
        align-items: center;
        transition: all 0.3s ease;
    }

        .choice-item:hover {
            border-color: #667eea;
            background: #f8f9ff;
        }

        .choice-item.selected {
            border-color: #667eea;
            background: #f3f4ff;
        }

    .choice-radio {
        accent-color: #667eea;
        transform: scale(1.2);
    }

    /* Navigation Buttons */
    .nav-buttons {
        display: flex;
        justify-content: space-between;
        gap: 15px;
        margin-top: auto;
    }

    .btn-nav {
        padding: 1rem 2rem;
        border-radius: 50px;
        font-weight: 600;
        font-size: 1rem;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .btn-previous {
        background: #6c757d;
        color: white;
    }

        .btn-previous:hover:not(:disabled) {
            background: #5a6268;
            transform: translateY(-2px);
        }

    .btn-next {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

        .btn-next:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(102, 126, 234, 0.4);
        }

    .btn-submit {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: white;
        flex: 1;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(40, 167, 69, 0.4);
        }

    .btn-nav:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    /* Sidebar */
    .sidebar-panel {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .sidebar-card {
        background: white;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 5px 20px rgba(0,0,0,.08);
        position: sticky;
        top: 20px;
    }

    .sidebar-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #212529;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .sidebar-title i {
            color: #667eea;
        }

    /* Question Grid */
    .question-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 10px;
        margin-bottom: 25px;
    }

    .question-nav-btn {
        aspect-ratio: 1;
        border: 2px solid #dee2e6;
        border-radius: 8px;
        background: white;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .question-nav-btn:hover {
            border-color: #667eea;
            background: rgba(102, 126, 234, 0.1);
        }

        .question-nav-btn.answered {
            background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
            color: white;
            border-color: #28a745;
        }

        .question-nav-btn.current {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-color: #667eea;
            transform: scale(1.1);
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
        }

    /* Progress */
    .progress-section {
        padding-top: 20px;
        border-top: 2px solid #e9ecef;
    }

    .progress-text {
        text-align: center;
        font-weight: 600;
        color: #6c757d;
        margin-bottom: 15px;
    }

    .progress-bar {
        height: 10px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 5px;
        transition: width 0.3s ease;
    }

    /* Responsive */
    @@media (max-width: 1200px) {
        .exam-layout {
            grid-template-columns: 1fr;
        }

        .sidebar-panel {
            order: -1;
        }

        .sidebar-card {
            position: relative;
            top: 0;
        }

        .question-grid {
            grid-template-columns: repeat(10, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .exam-header {
            padding: 20px;
        }

        .exam-info {
            flex-direction: column;
            text-align: center;
        }

        .question-card {
            padding: 20px;
        }

        .nav-buttons {
            flex-direction: column;
        }

        .btn-nav {
            width: 100%;
        }

        .question-grid {
            grid-template-columns: repeat(5, 1fr);
        }
    }
</style>

<div class="exam-container">
    <!-- Exam Header -->
    <div class="exam-header">
        <div class="d-flex justify-content-between align-items-center">
            <div class="exam-info">
                <div class="exam-icon">
                    <i class="fas fa-file-alt"></i>
                </div>
                <div class="exam-title">
                    <h2>@Model.ExamName</h2>
                    <div class="exam-course">
                        <i class="fas fa-book me-1"></i>@Model.CourseName
                    </div>
                </div>
            </div>
            <div class="timer-box" id="timer-container">
                <div class="timer-label">
                    <i class="fas fa-hourglass-half"></i>
                    Time Remaining
                </div>
                <div class="timer-display" id="timer">00:00:00</div>
            </div>
        </div>
    </div>

    <form id="examForm" asp-action="SubmitExam" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="ExamId" value="@Model.ExamId" />

        <div class="exam-layout">
            <!-- Questions Section -->
            <div>
                @for (int i = 0; i < Model.Questions.Count; i++)
                {
                    var q = Model.Questions[i];
                    <div class="question-card" id="question-@i" style="display: @(i == 0 ? "flex" : "none")">
                        <div class="question-header">
                            <div class="question-number">
                                <i class="fas fa-question-circle"></i>
                                Question @(i + 1) of @Model.Questions.Count
                            </div>
                            @if (q.Points > 0)
                            {
                                <div class="points-badge">
                                    <i class="fas fa-star"></i>
                                    @q.Points Points
                                </div>
                            }
                        </div>

                        <div class="question-text">@q.QuestionText</div>

                        <input type="hidden" name="Questions[@i].QuestionId" value="@q.QuestionId" />

                        <div class="choices-container">
                            @foreach (var choice in q.Choices)
                            {
                                <label class="choice-item">
                                    <input type="radio"
                                           class="choice-radio"
                                           name="Questions[@i].SelectedChoiceId"
                                           value="@choice.ChoiceId"
                                           required
                                           onchange="markAnswered(@i)" />
                                    <span>@choice.ChoiceText</span>
                                </label>
                            }
                        </div>

                        <div class="nav-buttons">
                            <button type="button" class="btn-nav btn-previous" id="btn-prev" onclick="prevQuestion()">
                                <i class="fas fa-chevron-left"></i>
                                Previous
                            </button>
                            <button type="button" class="btn-nav btn-submit" onclick="confirmSubmit()">
                                <i class="fas fa-paper-plane"></i>
                                Submit Exam
                            </button>
                            <button type="button" class="btn-nav btn-next" id="btn-next" onclick="nextQuestion()">
                                Next
                                <i class="fas fa-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                }
            </div>

            <!-- Sidebar -->
            <div class="sidebar-panel">
                <div class="sidebar-card">
                    <div class="sidebar-title">
                        <i class="fas fa-th"></i>
                        Quick Navigation
                    </div>

                    <div class="question-grid">
                        @for (int i = 0; i < Model.Questions.Count; i++)
                        {
                            <button type="button"
                                    class="question-nav-btn @(i == 0 ? "current" : "")"
                                    id="nav-@i"
                                    onclick="goToQuestion(@i)">
                                @(i + 1)
                            </button>
                        }
                    </div>

                    <div class="progress-section">
                        <div class="progress-text" id="progress-text">
                            0 / @Model.Questions.Count Answered
                        </div>
                        <div class="progress">
                            <div class="progress-bar" id="progress-bar" style="width: 0%"></div>
                        </div>
                    </div>

                    <div class="legend mt-3">
                        <small class="text-muted">
                            <i class="fas fa-square text-success"></i> Answered
                            <span class="ms-3"><i class="fas fa-square text-primary"></i> Current</span>
                            <span class="ms-3"><i class="fas fa-square text-secondary"></i> Unanswered</span>
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
    // وظائف النسخة الأولى مع تعديلات طفيفة
    let currentQuestion = 0;
    const totalQuestions = @Model.Questions.Count;
    let remainingTime = @remainingSeconds;
    let answered = new Set();
    let submitting = false;

    // Initialize
    document.addEventListener('DOMContentLoaded', function() {
        checkExistingAnswers();
        startTimer();
        updateNav();
    });

    function checkExistingAnswers() {
        for (let i = 0; i < totalQuestions; i++) {
            const selected = document.querySelector(`input[name="Questions[${i}].SelectedChoiceId"]:checked`);
            if (selected) {
                answered.add(i);
                document.getElementById(`nav-${i}`).classList.add('answered');
                selected.closest('.choice-item').classList.add('selected');
            }
        }
        updateProgress();
    }

    function startTimer() {
        updateTimerDisplay();
        setInterval(() => {
            remainingTime--;
            updateTimerDisplay();
            if (remainingTime <= 0) autoSubmit();
        }, 1000);
    }

    function updateTimerDisplay() {
        const h = Math.floor(remainingTime / 3600);
        const m = Math.floor((remainingTime % 3600) / 60);
        const s = remainingTime % 60;
        document.getElementById('timer').textContent =
            `${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
    }

    function goToQuestion(index) {
        // Hide current
        document.getElementById(`question-${currentQuestion}`).style.display = 'none';
        document.getElementById(`nav-${currentQuestion}`).classList.remove('current');

        // Show new
        document.getElementById(`question-${index}`).style.display = 'flex';
        document.getElementById(`nav-${index}`).classList.add('current');
        currentQuestion = index;

        updateNav();
    }

    function nextQuestion() {
        if (currentQuestion < totalQuestions - 1) goToQuestion(currentQuestion + 1);
    }

    function prevQuestion() {
        if (currentQuestion > 0) goToQuestion(currentQuestion - 1);
    }

    function updateNav() {
        document.getElementById('btn-prev').disabled = currentQuestion === 0;
        document.getElementById('btn-next').disabled = currentQuestion === totalQuestions - 1;
    }

    function markAnswered(index) {
        answered.add(index);
        document.getElementById(`nav-${index}`).classList.add('answered');

        // Update choice styling
        const choices = document.querySelectorAll(`#question-${index} .choice-item`);
        choices.forEach(c => c.classList.remove('selected'));

        const selected = document.querySelector(`input[name="Questions[${index}].SelectedChoiceId"]:checked`);
        if (selected) {
            selected.closest('.choice-item').classList.add('selected');
        }

        updateProgress();
    }

    function updateProgress() {
        const progress = (answered.size / totalQuestions) * 100;
        document.getElementById('progress-text').textContent = `${answered.size} / ${totalQuestions} Answered`;
        document.getElementById('progress-bar').style.width = `${progress}%`;
    }

    function confirmSubmit() {
        if (answered.size < totalQuestions) {
            const unanswered = totalQuestions - answered.size;
            if (!confirm(`You have ${unanswered} unanswered question(s). Are you sure you want to submit?`)) {
                return;
            }
        } else {
            if (!confirm("Are you sure you want to submit the exam?")) return;
        }
        submitExam();
    }

    function autoSubmit() {
        alert("Time is up! Exam will be submitted.");
        submitExam();
    }

    function submitExam() {
        if (submitting) return;
        submitting = true;
        document.querySelectorAll('button').forEach(b => b.disabled = true);
        document.getElementById('examForm').submit();
    }
</script>