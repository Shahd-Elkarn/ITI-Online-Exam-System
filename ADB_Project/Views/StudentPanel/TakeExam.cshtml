@model ADB_Project.Models.ViewModels.TakeExamVM

@{
    ViewData["Title"] = "Take Exam - " + Model.ExamName;
    int remainingSeconds = ViewBag.RemainingSeconds ?? 0;
}

<style>
    body {
        background-color: #f5f7fa;
    }

    .exam-header-card {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        border-radius: 15px;
        padding: 25px;
        margin-bottom: 25px;
    }

    .timer-display {
        background: rgba(255,255,255,.2);
        padding: 15px 25px;
        border-radius: 10px;
        text-align: center;
    }

    .timer-text {
        font-size: 2rem;
        font-weight: bold;
        font-family: monospace;
    }

    .question-card {
        background: white;
        border-radius: 15px;
        padding: 30px;
        box-shadow: 0 5px 20px rgba(0,0,0,.08);
        margin-bottom: 20px;
    }

    .choice-item {
        border: 2px solid #e9ecef;
        border-radius: 10px;
        padding: 15px;
        cursor: pointer;
        margin-bottom: 10px;
        display: flex;
        gap: 10px;
        align-items: center;
    }

        .choice-item.selected {
            border-color: #667eea;
            background: #f3f4ff;
        }

    .choice-radio {
        accent-color: #667eea;
    }

    .nav-btn {
        padding: 12px 25px;
        border-radius: 25px;
        border: none;
        font-weight: 600;
    }

    .btn-prev {
        background: #6c757d;
        color: white;
    }

    .btn-next {
        background: #667eea;
        color: white;
    }

    .btn-submit {
        background: #28a745;
        color: white;
    }

    .question-nav-btn {
        width: 45px;
        height: 45px;
        border-radius: 8px;
        border: 2px solid #e9ecef;
        font-weight: bold;
    }

        .question-nav-btn.current {
            background: #667eea;
            color: white;
        }

        .question-nav-btn.answered {
            background: #28a745;
            color: white;
            border-color: #28a745;
        }
</style>

<div class="container-fluid mt-4 mb-5">

    <!-- HEADER -->
    <div class="exam-header-card">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h3>@Model.ExamName</h3>
                <p>@Model.CourseName</p>
            </div>
            <div class="col-md-6 text-end">
                <div class="timer-display" id="timerBox">
                    <div>Time Remaining</div>
                    <div class="timer-text" id="timer">00:00:00</div>
                </div>
            </div>
        </div>
    </div>

    <form id="examForm" asp-action="SubmitExam" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="ExamId" value="@Model.ExamId" />

        <div class="row">
            <!-- QUESTIONS -->
            <div class="col-lg-8">

                @for (int i = 0; i < Model.Questions.Count; i++)
                {
                    var q = Model.Questions[i];
                    <div class="question-card" id="question-@i" style="display:@(i == 0 ? "block" : "none")">
                        <h5>Question @(i + 1) / @Model.Questions.Count</h5>
                        <p>@q.QuestionText</p>

                        <input type="hidden" name="Questions[@i].QuestionId" value="@q.QuestionId" />

                        @foreach (var c in q.Choices)
                        {
                            <label class="choice-item">
                                <input type="radio"
                                       class="choice-radio"
                                       name="Questions[@i].SelectedChoiceId"
                                       value="@c.ChoiceId"
                                       required
                                       onchange="markAnswered(@i)" />
                                <span>@c.ChoiceText</span>
                            </label>
                        }
                    </div>
                }

                <!-- NAV -->
                <div class="d-flex justify-content-between mt-4">
                    <button type="button" class="nav-btn btn-prev" onclick="prevQ()">Previous</button>
                    <button type="button" class="nav-btn btn-submit" onclick="confirmSubmit()">Submit</button>
                    <button type="button" class="nav-btn btn-next" onclick="nextQ()">Next</button>
                </div>
            </div>

            <!-- SIDEBAR -->
            <div class="col-lg-4">
                <div class="question-card">
                    <h6>Quick Navigation</h6>
                    <div class="d-grid gap-2" style="grid-template-columns:repeat(4,1fr); display:grid;">
                        @for (int i = 0; i < Model.Questions.Count; i++)
                        {
                            <button type="button"
                                    id="nav-@i"
                                    class="question-nav-btn @(i == 0 ? "current" : "")"
                                    onclick="goTo(@i)">
                                @(i + 1)
                            </button>
                        }
                    </div>
                    <p class="text-center mt-3" id="progressText">0 / @Model.Questions.Count Answered</p>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
    let current = 0;
    const total = @Model.Questions.Count;
    let remaining = @remainingSeconds;
    let answered = new Set();
    let submitting = false;

    function showTimer() {
        const h = Math.floor(remaining / 3600);
        const m = Math.floor((remaining % 3600) / 60);
        const s = remaining % 60;
        timer.textContent = `${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
    }

    setInterval(() => {
        remaining--;
        showTimer();
        if (remaining <= 0) autoSubmit();
    }, 1000);

    function goTo(i) {
        document.getElementById(`question-${current}`).style.display = 'none';
        document.getElementById(`question-${i}`).style.display = 'block';
        document.getElementById(`nav-${current}`).classList.remove('current');
        document.getElementById(`nav-${i}`).classList.add('current');
        current = i;
    }

    function nextQ() { if (current < total-1) goTo(current+1); }
    function prevQ() { if (current > 0) goTo(current-1); }

    function markAnswered(i) {
        answered.add(i);
        document.getElementById(`nav-${i}`).classList.add('answered');
        document.getElementById('progressText').innerText =
            `${answered.size} / ${total} Answered`;

        document.querySelectorAll(`#question-${i} .choice-item`)
            .forEach(x => x.classList.remove('selected'));
        event.target.closest('.choice-item').classList.add('selected');
    }

    function confirmSubmit() {
        if (confirm("Are you sure you want to submit the exam?")) submitExam();
    }

    function autoSubmit() {
        alert("Time is up! Exam will be submitted.");
        submitExam();
    }

    function submitExam() {
        if (submitting) return;
        submitting = true;
        document.querySelectorAll('button').forEach(b => b.disabled = true);
        examForm.submit();
    }

    showTimer();
</script>
