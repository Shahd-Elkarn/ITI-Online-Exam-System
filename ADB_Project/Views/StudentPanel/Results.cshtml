@model List<ADB_Project.Models.ViewModels.ExamResultSummaryVM>

@{
    ViewData["Title"] = "My Results";
}

<link rel="stylesheet" href="~/css/unified-design.css" />

<style>
    .results-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: var(--spacing-xl);
    }

    /* Page Header */
    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: var(--radius-xl);
        padding: var(--spacing-2xl);
        margin-bottom: var(--spacing-xl);
        box-shadow: 0 10px 40px rgba(102, 126, 234, 0.3);
    }

    .header-content h2 {
        font-size: 2rem;
        margin-bottom: var(--spacing-sm);
    }

    .header-content p {
        opacity: 0.95;
        margin: 0;
    }

    /* Summary Stats */
    .summary-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: var(--spacing-lg);
        margin-bottom: var(--spacing-xl);
    }

    .summary-card {
        background: var(--bg-secondary);
        border-radius: var(--radius-xl);
        padding: var(--spacing-xl);
        box-shadow: var(--shadow-lg);
        text-align: center;
        transition: all var(--transition-base);
        border-top: 4px solid;
    }

    .summary-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-xl);
    }

    .summary-card.total {
        border-top-color: var(--primary-start);
    }

    .summary-card.passed {
        border-top-color: var(--success);
    }

    .summary-card.failed {
        border-top-color: var(--danger);
    }

    .summary-card.average {
        border-top-color: var(--info);
    }

    .summary-icon {
        width: 60px;
        height: 60px;
        margin: 0 auto var(--spacing-md);
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
    }

    .summary-card.total .summary-icon {
        background: rgba(102, 126, 234, 0.1);
        color: var(--primary-start);
    }

    .summary-card.passed .summary-icon {
        background: rgba(16, 185, 129, 0.1);
        color: var(--success);
    }

    .summary-card.failed .summary-icon {
        background: rgba(239, 68, 68, 0.1);
        color: var(--danger);
    }

    .summary-card.average .summary-icon {
        background: rgba(59, 130, 246, 0.1);
        color: var(--info);
    }

    .summary-value {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: var(--spacing-xs);
    }

    .summary-label {
        color: var(--text-secondary);
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 600;
    }

    /* Filters */
    .filters-card {
        background: var(--bg-secondary);
        border-radius: var(--radius-xl);
        padding: var(--spacing-lg) var(--spacing-xl);
        box-shadow: var(--shadow-md);
        margin-bottom: var(--spacing-xl);
    }

    .filters-row {
        display: flex;
        gap: var(--spacing-md);
        align-items: center;
        flex-wrap: wrap;
    }

    .filter-group {
        flex: 1;
        min-width: 200px;
    }

    .filter-label {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text-secondary);
        margin-bottom: var(--spacing-xs);
    }

    .filter-select {
        width: 100%;
        padding: 0.75rem;
        border: 2px solid var(--gray-300);
        border-radius: var(--radius-md);
        font-size: 1rem;
        transition: all var(--transition-base);
    }

    .filter-select:focus {
        outline: none;
        border-color: var(--primary-start);
    }

    /* Results Table */
    .results-table-card {
        background: var(--bg-secondary);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-lg);
        overflow: hidden;
    }

    .table-header {
        padding: var(--spacing-lg) var(--spacing-xl);
        background: var(--gray-50);
        border-bottom: 2px solid var(--gray-200);
    }

    .table-header h4 {
        margin: 0;
        font-size: 1.25rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
    }

    .results-table {
        width: 100%;
        border-collapse: collapse;
    }

    .results-table thead {
        background: var(--gray-100);
    }

    .results-table th {
        padding: var(--spacing-lg);
        text-align: left;
        font-weight: 700;
        color: var(--text-primary);
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .results-table td {
        padding: var(--spacing-lg);
        border-bottom: 1px solid var(--gray-200);
    }

    .results-table tbody tr {
        transition: all var(--transition-base);
    }

    .results-table tbody tr:hover {
        background: var(--gray-50);
    }

    .exam-name-cell {
        font-weight: 600;
        color: var(--text-primary);
    }

    .course-name {
        font-size: 0.875rem;
        color: var(--text-secondary);
        margin-top: var(--spacing-xs);
    }

    .score-cell {
        font-weight: 700;
        font-size: 1.125rem;
    }

    .percentage-badge {
        display: inline-flex;
        align-items: center;
        gap: var(--spacing-xs);
        padding: 0.5rem 1rem;
        border-radius: var(--radius-full);
        font-weight: 700;
        font-size: 1rem;
    }

    .percentage-badge.excellent {
        background: rgba(16, 185, 129, 0.1);
        color: var(--success);
    }

    .percentage-badge.good {
        background: rgba(59, 130, 246, 0.1);
        color: var(--info);
    }

    .percentage-badge.average {
        background: rgba(245, 158, 11, 0.1);
        color: var(--warning);
    }

    .percentage-badge.poor {
        background: rgba(239, 68, 68, 0.1);
        color: var(--danger);
    }

    .grade-badge {
        display: inline-block;
        padding: 0.5rem 1rem;
        border-radius: var(--radius-md);
        font-weight: 700;
        font-size: 1.125rem;
    }

    .grade-a {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: white;
    }

    .grade-b {
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        color: white;
    }

    .grade-c {
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        color: white;
    }

    .grade-d, .grade-f {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        color: white;
    }

    .status-badge {
        padding: 0.5rem 1rem;
        border-radius: var(--radius-full);
        font-weight: 600;
        font-size: 0.875rem;
    }

    .status-pass {
        background: rgba(16, 185, 129, 0.1);
        color: var(--success);
    }

    .status-fail {
        background: rgba(239, 68, 68, 0.1);
        color: var(--danger);
    }

    .date-text {
        color: var(--text-secondary);
        font-size: 0.875rem;
    }

    .btn-view {
        padding: 0.5rem 1.25rem;
        border-radius: var(--radius-full);
        background: linear-gradient(135deg, var(--primary-start) 0%, var(--primary-end) 100%);
        color: white;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.875rem;
        transition: all var(--transition-base);
        display: inline-flex;
        align-items: center;
        gap: var(--spacing-xs);
    }

    .btn-view:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
        color: white;
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: var(--spacing-2xl);
    }

    .empty-icon {
        font-size: 5rem;
        color: var(--gray-300);
        margin-bottom: var(--spacing-lg);
    }

    .empty-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-secondary);
        margin-bottom: var(--spacing-sm);
    }

    .empty-text {
        color: var(--text-secondary);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .results-table {
            font-size: 0.875rem;
        }

        .results-table th,
        .results-table td {
            padding: var(--spacing-md);
        }

        .summary-stats {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="results-container">
    <!-- Page Header -->
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center">
            <div class="header-content">
                <h2>
                    <i class="fas fa-chart-line me-2"></i>
                    My Exam Results
                </h2>
                <p>View your exam performance and grades</p>
            </div>
            <a asp-action="Dashboard" class="btn btn-outline" style="background: rgba(255,255,255,0.2); border-color: white; color: white;">
                <i class="fas fa-arrow-left"></i>
                Back
            </a>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        
            var totalExams = Model.Count;
            var passedExams = Model.Count(r => r.Status == "Pass");
            var failedExams = Model.Count(r => r.Status == "Fail");
            var averagePercentage = Model.Any() ? Model.Average(r => r.Percentage) : 0;
        

        <!-- Summary Stats -->
        <div class="summary-stats">
            <div class="summary-card total">
                <div class="summary-icon">
                    <i class="fas fa-clipboard-list"></i>
                </div>
                <div class="summary-value">@totalExams</div>
                <div class="summary-label">Total Exams</div>
            </div>

            <div class="summary-card passed">
                <div class="summary-icon">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div class="summary-value">@passedExams</div>
                <div class="summary-label">Passed</div>
            </div>

            <div class="summary-card failed">
                <div class="summary-icon">
                    <i class="fas fa-times-circle"></i>
                </div>
                <div class="summary-value">@failedExams</div>
                <div class="summary-label">Failed</div>
            </div>

            <div class="summary-card average">
                <div class="summary-icon">
                    <i class="fas fa-chart-bar"></i>
                </div>
                <div class="summary-value">@averagePercentage.ToString("F1")%</div>
                <div class="summary-label">Average Score</div>
            </div>
        </div>

        <!-- Filters -->
        <div class="filters-card">
            <div class="filters-row">
                <div class="filter-group">
                    <label class="filter-label">Filter by Status</label>
                    <select class="filter-select" id="statusFilter">
                        <option value="all">All Results</option>
                        <option value="pass">Passed Only</option>
                        <option value="fail">Failed Only</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label class="filter-label">Sort by</label>
                    <select class="filter-select" id="sortFilter">
                        <option value="date">Date (Newest First)</option>
                        <option value="percentage">Percentage (Highest First)</option>
                        <option value="name">Exam Name (A-Z)</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label class="filter-label">Search</label>
                    <input type="text" class="filter-select" id="searchInput" placeholder="Search exams...">
                </div>
            </div>
        </div>

        <!-- Results Table -->
        <div class="results-table-card">
            <div class="table-header">
                <h4>
                    <i class="fas fa-list"></i>
                    Exam Results
                </h4>
            </div>

            <table class="results-table">
                <thead>
                    <tr>
                        <th>Exam</th>
                        <th>Score</th>
                        <th>Percentage</th>
                        <th>Grade</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="resultsTableBody">
                    @foreach (var result in Model)
                    {
                        var percentageClass = result.Percentage >= 85 ? "excellent" :
                                            result.Percentage >= 75 ? "good" :
                                            result.Percentage >= 60 ? "average" : "poor";
                        
                        var gradeClass = result.Grade.ToLower().Replace("+", "").Replace("-", "");
                        
                        <tr class="result-row" 
                            data-status="@result.Status.ToLower()" 
                            data-percentage="@result.Percentage"
                            data-name="@result.ExamName.ToLower()"
                            data-date="@result.GradeDate?.ToString("yyyyMMdd")">
                            <td>
                                <div class="exam-name-cell">@result.ExamName</div>
                                <div class="course-name">
                                    <i class="fas fa-book me-1"></i>@result.CourseName
                                </div>
                            </td>
                            <td class="score-cell">
                                @result.TotalScore / @result.MaxScore
                            </td>
                            <td>
                                <span class="percentage-badge @percentageClass">
                                    @result.Percentage.ToString("F1")%
                                </span>
                            </td>
                            <td>
                                <span class="grade-badge grade-@gradeClass">
                                    @result.Grade
                                </span>
                            </td>
                            <td>
                                <span class="status-badge @(result.Status == "Pass" ? "status-pass" : "status-fail")">
                                    @result.Status
                                </span>
                            </td>
                            <td class="date-text">
                                @result.GradeDate?.ToString("MMM dd, yyyy")
                            </td>
                            <td>
                                <a asp-action="ExamResult" asp-route-examId="@result.ExamId" class="btn-view">
                                    <i class="fas fa-eye"></i>
                                    View Details
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="results-table-card">
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="fas fa-chart-line"></i>
                </div>
                <h3 class="empty-title">No Results Available</h3>
                <p class="empty-text">You haven't completed any exams yet. Take an exam to see your results here.</p>
                <a asp-action="Exams" class="btn btn-primary mt-4">
                    <i class="fas fa-file-alt me-2"></i>
                    Go to Exams
                </a>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Filter and Search
        const statusFilter = document.getElementById('statusFilter');
        const sortFilter = document.getElementById('sortFilter');
        const searchInput = document.getElementById('searchInput');
        const tableBody = document.getElementById('resultsTableBody');

        function applyFilters() {
            const rows = Array.from(tableBody.querySelectorAll('.result-row'));
            const statusValue = statusFilter.value;
            const searchValue = searchInput.value.toLowerCase();

            // Filter
            rows.forEach(row => {
                const status = row.dataset.status;
                const name = row.dataset.name;
                
                const statusMatch = statusValue === 'all' || status === statusValue;
                const searchMatch = searchValue === '' || name.includes(searchValue);

                row.style.display = statusMatch && searchMatch ? '' : 'none';
            });

            // Sort
            const sortValue = sortFilter.value;
            rows.sort((a, b) => {
                if (sortValue === 'date') {
                    return b.dataset.date.localeCompare(a.dataset.date);
                } else if (sortValue === 'percentage') {
                    return parseFloat(b.dataset.percentage) - parseFloat(a.dataset.percentage);
                } else {
                    return a.dataset.name.localeCompare(b.dataset.name);
                }
            });

            rows.forEach(row => tableBody.appendChild(row));
        }

        statusFilter?.addEventListener('change', applyFilters);
        sortFilter?.addEventListener('change', applyFilters);
        searchInput?.addEventListener('input', applyFilters);
    </script>
}