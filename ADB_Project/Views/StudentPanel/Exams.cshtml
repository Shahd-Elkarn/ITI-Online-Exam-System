@using ADB_Project.Models.ViewModels
@model List<StudentExamListVM>

@{
    ViewData["Title"] = "My Exams";
}

<link rel="stylesheet" href="~/css/unified-design.css" />

<style>
    .exams-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: var(--spacing-xl);
    }

    /* Page Header */
    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: var(--radius-xl);
        padding: var(--spacing-2xl);
        margin-bottom: var(--spacing-xl);
        box-shadow: 0 10px 40px rgba(102, 126, 234, 0.3);
        position: relative;
        overflow: hidden;
    }

        .page-header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 400px;
            height: 400px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
        }

    .header-content {
        position: relative;
        z-index: 1;
    }

    .page-title {
        font-size: 2rem;
        margin-bottom: var(--spacing-sm);
        display: flex;
        align-items: center;
        gap: var(--spacing-md);
    }

    .page-subtitle {
        opacity: 0.95;
        font-size: 1.125rem;
    }

    /* Stats Cards */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: var(--spacing-lg);
        margin-bottom: var(--spacing-xl);
    }

    .stat-card {
        background: var(--bg-secondary);
        border-radius: var(--radius-xl);
        padding: var(--spacing-xl);
        box-shadow: var(--shadow-lg);
        text-align: center;
        transition: all var(--transition-base);
        border-top: 4px solid;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-xl);
        }

        .stat-card.primary {
            border-top-color: var(--primary-start);
        }

        .stat-card.warning {
            border-top-color: var(--warning);
        }

        .stat-card.success {
            border-top-color: var(--success);
        }

    .stat-icon {
        width: 50px;
        height: 50px;
        margin: 0 auto var(--spacing-md);
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }

    .stat-card.primary .stat-icon {
        background: rgba(102, 126, 234, 0.1);
        color: var(--primary-start);
    }

    .stat-card.warning .stat-icon {
        background: rgba(245, 158, 11, 0.1);
        color: var(--warning);
    }

    .stat-card.success .stat-icon {
        background: rgba(16, 185, 129, 0.1);
        color: var(--success);
    }

    .stat-number {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: var(--spacing-xs);
    }

    .stat-label {
        color: var(--text-secondary);
        font-size: 0.875rem;
        font-weight: 600;
    }

    /* Filters */
    .filters-section {
        background: var(--bg-secondary);
        border-radius: var(--radius-xl);
        padding: var(--spacing-lg) var(--spacing-xl);
        box-shadow: var(--shadow-md);
        margin-bottom: var(--spacing-xl);
    }

    .search-box {
        position: relative;
    }

    .search-input {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 3rem;
        border: 2px solid var(--gray-300);
        border-radius: var(--radius-full);
        font-size: 1rem;
        transition: all var(--transition-base);
    }

        .search-input:focus {
            outline: none;
            border-color: var(--primary-start);
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

    .search-icon {
        position: absolute;
        left: 1.25rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-secondary);
    }

    /* Exams Grid */
    .exams-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: var(--spacing-xl);
    }

    .exam-card {
        background: var(--bg-secondary);
        border-radius: var(--radius-xl);
        padding: var(--spacing-xl);
        box-shadow: var(--shadow-lg);
        transition: all var(--transition-base);
        position: relative;
        overflow: hidden;
        border: 2px solid transparent;
    }

        .exam-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 5px;
        }

        .exam-card.not-started::before {
            background: linear-gradient(90deg, var(--primary-start) 0%, var(--primary-end) 100%);
        }

        .exam-card.in-progress::before {
            background: linear-gradient(90deg, var(--warning) 0%, #d97706 100%);
        }

        .exam-card.submitted::before {
            background: linear-gradient(90deg, var(--success) 0%, #059669 100%);
        }

        .exam-card:hover {
            transform: translateY(-8px);
            box-shadow: var(--shadow-xl);
            border-color: var(--primary-start);
        }

    .exam-header {
        display: flex;
        justify-content: space-between;
        align-items: start;
        margin-bottom: var(--spacing-lg);
        padding-bottom: var(--spacing-lg);
        border-bottom: 2px solid var(--gray-200);
    }

    .exam-title-section h3 {
        font-size: 1.25rem;
        margin-bottom: var(--spacing-xs);
        color: var(--text-primary);
    }

    .exam-course {
        display: flex;
        align-items: center;
        gap: var(--spacing-xs);
        color: var(--text-secondary);
        font-size: 0.875rem;
    }

    .status-badge {
        padding: 0.5rem 1rem;
        border-radius: var(--radius-full);
        font-size: 0.875rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .status-not-started {
        background: rgba(102, 126, 234, 0.1);
        color: var(--primary-start);
    }

    .status-in-progress {
        background: rgba(245, 158, 11, 0.1);
        color: var(--warning);
    }

    .status-submitted {
        background: rgba(16, 185, 129, 0.1);
        color: var(--success);
    }

    .exam-meta {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--spacing-md);
        padding: var(--spacing-md);
        background: var(--gray-50);
        border-radius: var(--radius-lg);
        margin-bottom: var(--spacing-lg);
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        font-size: 0.875rem;
        color: var(--text-secondary);
    }

        .meta-item i {
            color: var(--primary-start);
        }

        .meta-item strong {
            color: var(--text-primary);
        }

    .exam-dates {
        margin-bottom: var(--spacing-lg);
    }

    .date-item {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        padding: var(--spacing-sm) 0;
        font-size: 0.875rem;
        color: var(--text-secondary);
    }

        .date-item i {
            color: var(--primary-start);
            width: 20px;
        }

    .overdue-badge {
        display: inline-flex;
        align-items: center;
        gap: var(--spacing-xs);
        background: var(--danger);
        color: white;
        padding: 0.25rem 0.75rem;
        border-radius: var(--radius-full);
        font-size: 0.75rem;
        font-weight: 600;
        margin-left: var(--spacing-sm);
        animation: pulse 2s infinite;
    }

    .exam-actions {
        display: flex;
        gap: var(--spacing-sm);
    }

    .btn-exam {
        flex: 1;
        padding: 0.875rem 1.5rem;
        border-radius: var(--radius-full);
        font-weight: 600;
        font-size: 0.95rem;
        border: none;
        cursor: pointer;
        transition: all var(--transition-base);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--spacing-sm);
        text-decoration: none;
    }

    .btn-start {
        background: linear-gradient(135deg, var(--primary-start) 0%, var(--primary-end) 100%);
        color: white;
    }

        .btn-start:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(102, 126, 234, 0.4);
            color: white;
        }

    .btn-continue {
        background: linear-gradient(135deg, var(--warning) 0%, #d97706 100%);
        color: white;
    }

        .btn-continue:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(245, 158, 11, 0.4);
            color: white;
        }

    .btn-result {
        background: linear-gradient(135deg, var(--success) 0%, #059669 100%);
        color: white;
    }

        .btn-result:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(16, 185, 129, 0.4);
            color: white;
        }

    .btn-disabled {
        background: var(--gray-400);
        color: white;
        cursor: not-allowed;
        opacity: 0.7;
    }

    .btn-expired {
        background: var(--danger);
        color: white;
        cursor: not-allowed;
    }

    /* Empty State */
    .empty-state {
        background: var(--bg-secondary);
        border-radius: var(--radius-xl);
        padding: var(--spacing-2xl);
        text-align: center;
        box-shadow: var(--shadow-lg);
    }

    .empty-icon {
        font-size: 5rem;
        color: var(--gray-300);
        margin-bottom: var(--spacing-lg);
    }

    .empty-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-secondary);
        margin-bottom: var(--spacing-sm);
    }

    .empty-text {
        color: var(--text-secondary);
        margin-bottom: var(--spacing-xl);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .exams-grid {
            grid-template-columns: 1fr;
        }

        .stats-grid {
            grid-template-columns: 1fr;
        }

        .page-title {
            font-size: 1.5rem;
        }
    }
</style>

<div class="exams-container">
    <!-- Page Header -->
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center">
            <div class="header-content">
                <h1 class="page-title">
                    <i class="fas fa-file-alt"></i>
                    My Exams
                </h1>
                <p class="page-subtitle mb-0">View and take your assigned exams</p>
            </div>
            <a asp-action="Dashboard" class="btn btn-outline" style="background: rgba(255,255,255,0.2); border-color: white; color: white;">
                <i class="fas fa-arrow-left"></i>
                Back
            </a>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <!-- Stats Cards -->
        <div class="stats-grid">
            <div class="stat-card primary">
                <div class="stat-icon">
                    <i class="fas fa-clipboard-list"></i>
                </div>
                <div class="stat-number">@Model.Count</div>
                <div class="stat-label">Total Exams</div>
            </div>

            <div class="stat-card warning">
                <div class="stat-icon">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="stat-number">@Model.Count(e => e.HasStarted && !e.HasSubmitted)</div>
                <div class="stat-label">In Progress</div>
            </div>

            <div class="stat-card success">
                <div class="stat-icon">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div class="stat-number">@Model.Count(e => e.HasSubmitted)</div>
                <div class="stat-label">Submitted</div>
            </div>
        </div>

        <!-- Search Filter -->
        <div class="filters-section">
            <div class="search-box">
                <i class="fas fa-search search-icon"></i>
                <input type="text"
                       class="search-input"
                       id="searchInput"
                       placeholder="Search exams by name or course...">
            </div>
        </div>

        <!-- Exams Grid -->
        <div class="exams-grid" id="examsGrid">
            @foreach (var exam in Model)
            {
                var now = DateTime.Now;
                var canAccessExam = !exam.ExamDate.HasValue || now >= exam.ExamDate.Value;
                var isExpired = exam.DueDate.HasValue && now > exam.DueDate.Value;

                var statusClass = exam.HasSubmitted ? "submitted" : exam.HasStarted ? "in-progress" : "not-started";
                var statusBadgeClass = exam.HasSubmitted ? "status-submitted" : exam.HasStarted ? "status-in-progress" : "status-not-started";
                var statusText = exam.HasSubmitted ? "Submitted" : exam.HasStarted ? "In Progress" : "Not Started";

                <div class="exam-card @statusClass"
                     data-exam-name="@exam.ExamName.ToLower()"
                     data-course-name="@exam.CourseName.ToLower()">

                    <div class="exam-header">
                        <div class="exam-title-section">
                            <h3>@exam.ExamName</h3>
                            <div class="exam-course">
                                <i class="fas fa-book-open"></i>
                                <span>@exam.CourseName</span>
                            </div>
                        </div>
                        <span class="status-badge @statusBadgeClass">@statusText</span>
                    </div>

                    <div class="exam-meta">
                        <div class="meta-item">
                            <i class="fas fa-clock"></i>
                            <span><strong>@exam.DurationMinutes</strong> minutes</span>
                        </div>
                        <div class="meta-item">
                            <i class="fas fa-question-circle"></i>
                            <span><strong>@exam.TotalQuestions</strong> questions</span>
                        </div>
                    </div>

                    <div class="exam-dates">
                        @if (exam.ExamDate.HasValue)
                        {
                            <div class="date-item">
                                <i class="fas fa-calendar-alt"></i>
                                <span>Starts: <strong>@exam.ExamDate.Value.ToString("ddd, dd MMM yyyy HH:mm")</strong></span>
                            </div>
                        }
                        @if (exam.DueDate.HasValue)
                        {
                            var isOverdue = exam.DueDate < now && !exam.HasSubmitted;
                            <div class="date-item">
                                <i class="fas fa-hourglass-end"></i>
                                <span>Due: <strong>@exam.DueDate.Value.ToString("dd MMM yyyy HH:mm")</strong></span>
                                @if (isOverdue)
                                {
                                    <span class="overdue-badge">
                                        <i class="fas fa-exclamation-triangle"></i>
                                        Overdue
                                    </span>
                                }
                            </div>
                        }
                    </div>

                    <div class="exam-actions">
                        @if (exam.HasSubmitted)
                        {
                            @if (exam.HasGrade)
                            {
                                <a asp-action="ExamResult" asp-route-examId="@exam.ExamId" class="btn-exam btn-result">
                                    <i class="fas fa-chart-line"></i>
                                    View Result
                                </a>
                            }
                            else
                            {
                                <button class="btn-exam btn-disabled" disabled>
                                    <i class="fas fa-hourglass-half"></i>
                                    Awaiting Grade
                                </button>
                            }
                        }
                        else if (isExpired)
                        {
                            <button class="btn-exam btn-expired" disabled>
                                <i class="fas fa-times-circle"></i>
                                Exam Expired
                            </button>
                        }
                        else if (!canAccessExam)
                        {
                            <button class="btn-exam btn-disabled" disabled>
                                <i class="fas fa-lock"></i>
                                Not Available Yet
                            </button>
                        }
                        else if (exam.HasStarted)
                        {
                            <a asp-action="TakeExam" asp-route-examId="@exam.ExamId" class="btn-exam btn-continue">
                                <i class="fas fa-edit"></i>
                                Continue Exam
                            </a>
                        }
                        else
                        {
                            <form asp-action="StartExam" asp-route-examId="@exam.ExamId" method="post" style="flex: 1;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-exam btn-start" style="width: 100%;">
                                    <i class="fas fa-play"></i>
                                    Start Exam
                                </button>
                            </form>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">
                <i class="fas fa-inbox"></i>
            </div>
            <h3 class="empty-title">No Exams Assigned Yet</h3>
            <p class="empty-text">Your instructor will assign exams soon. Check back later!</p>
            <a asp-action="Dashboard" class="btn btn-primary">
                <i class="fas fa-arrow-left me-2"></i>
                Back to Dashboard
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Search functionality
        const searchInput = document.getElementById('searchInput');
        const examsGrid = document.getElementById('examsGrid');

        if (searchInput && examsGrid) {
            searchInput.addEventListener('input', function() {
                const searchTerm = this.value.toLowerCase();
                const examCards = examsGrid.querySelectorAll('.exam-card');

                examCards.forEach(card => {
                    const examName = card.dataset.examName;
                    const courseName = card.dataset.courseName;

                    if (examName.includes(searchTerm) || courseName.includes(searchTerm)) {
                        card.style.display = 'block';
                    } else {
                        card.style.display = 'none';
                    }
                });
            });
        }

        // Add animation on load
        document.addEventListener('DOMContentLoaded', function() {
            const cards = document.querySelectorAll('.exam-card');
            cards.forEach((card, index) => {
                card.style.animation = `fadeIn 0.5s ease ${index * 0.1}s forwards`;
                card.style.opacity = '0';
            });
        });
    </script>
}