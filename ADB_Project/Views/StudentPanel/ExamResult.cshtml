@using ADB_Project.Models.ViewModels
@model ExamResultVM

@{
    ViewData["Title"] = "Exam Result";
}

<style>
    body {
        background-color: #f5f7fa;
    }

    /* ===== Result Header ===== */
    .result-header {
        text-align: center;
        margin-bottom: 40px;
    }

    /* ===== Score Card ===== */
    .score-card {
        border-radius: 15px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.08);
    }

    /* ===== Answer Review ===== */
    .answer-list {
        list-style: none;
        padding: 0;
        margin-top: 15px;
    }

    .answer-item {
        padding: 12px 15px;
        border-radius: 8px;
        margin-bottom: 8px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .answer-correct {
        background: #e6f4ea;
        color: #198754;
        border-left: 5px solid #198754;
    }

    .answer-student {
        background: #fff3cd;
        color: #856404;
        border-left: 5px solid #ffc107;
    }

    .answer-normal {
        background: #f8f9fa;
        color: #495057;
        border-left: 5px solid #dee2e6;
    }

    .accordion-button {
        font-weight: 600;
    }
</style>

<div class="container mt-5 mb-5">

    <!-- ===== HEADER ===== -->
    <div class="result-header">
        @if (Model.Status == "Pass")
        {
            <i class="fas fa-trophy fa-4x text-success mb-3"></i>
            <h1 class="fw-bold text-success">Congratulations 🎉</h1>
        }
        else
        {
            <i class="fas fa-heart-broken fa-4x text-danger mb-3"></i>
            <h1 class="fw-bold text-danger">Better Luck Next Time</h1>
        }

        <h3 class="mt-3">@Model.ExamName</h3>
        <p class="text-muted">@Model.CourseName</p>
    </div>

    <!-- ===== SCORE CARD ===== -->
    <div class="row justify-content-center mb-5">
        <div class="col-lg-8">
            <div class="card score-card border-0">
                <div class="card-body text-center p-5">
                    <div class="row">
                        <div class="col-md-4">
                            <h5 class="text-muted">Your Score</h5>
                            <h2 class="fw-bold text-primary">
                                @Model.TotalScore / @Model.MaxScore
                            </h2>
                        </div>
                        <div class="col-md-4">
                            <h5 class="text-muted">Percentage</h5>
                            <h2 class="fw-bold @(Model.Percentage >= 50 ? "text-success" : "text-danger")">
                                @Model.Percentage.ToString("F1")%
                            </h2>
                        </div>
                        <div class="col-md-4">
                            <h5 class="text-muted">Grade</h5>
                            <h2 class="fw-bold @(Model.Status == "Pass" ? "text-success" : "text-danger")">
                                @Model.Grade
                            </h2>
                        </div>
                    </div>

                    <div class="mt-4">
                        <span class="badge fs-4 px-4 py-3 @(Model.Status == "Pass" ? "bg-success" : "bg-danger")">
                            @Model.Status
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== ANSWER REVIEW ===== -->
    <div class="row">
        <div class="col-12">
            <h3 class="text-center mb-4">Your Answers Review</h3>

            <div class="accordion" id="answersAccordion">
                @for (int i = 0; i < Model.FormattedAnswers.Count; i++)
                {
                    var answer = Model.FormattedAnswers[i];
                    <div class="accordion-item mb-2">
                        <h2 class="accordion-header" id="heading@(i)">
                            <button class="accordion-button collapsed"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#collapse@(i)">
                                Question @(i + 1)
                            </button>
                        </h2>

                        <div id="collapse@(i)"
                             class="accordion-collapse collapse"
                             data-bs-parent="#answersAccordion">
                            <div class="accordion-body">
                                <p class="fw-bold mb-3">@answer.QuestionText</p>

                                <ul class="answer-list">
                                    @foreach (var line in answer.Choices.Split("\n"))
                                    {
                                        var text = line.Trim();

                                        if (text.Contains("Correct Answer"))
                                        {
                                            <li class="answer-item answer-correct">
                                                <i class="fas fa-check-circle"></i>
                                                @text.Replace("✔", "")
                                              
                                            </li>
                                        }
                                        else if (text.Contains("Student Answer"))
                                        {
                                            <li class="answer-item answer-student">
                                                <i class="fas fa-user-check"></i>
                                                @text.Replace("←", "")
                                                
                                            </li>
                                        }
                                        else
                                        {
                                            <li class="answer-item answer-normal">
                                                <i class="fas fa-circle text-muted"></i>
                                                @text
                                            </li>
                                        }
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ===== BACK BUTTON ===== -->
    <div class="text-center mt-5">
        <a asp-action="Exams" class="btn btn-primary btn-lg px-5">
            <i class="fas fa-arrow-left me-2"></i>
            Back to Exams
        </a>
    </div>

</div>
